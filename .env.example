# Copy to .env and fill in real values before deploying. .env is gitignored —
# never put real secrets in application.properties or commit this file
# without renaming it back to .env.example first.
#
# Spring Boot reads these via relaxed env-var binding (SPRING_DATASOURCE_URL
# -> spring.datasource.url, APP_S3_BUCKET -> app.s3.bucket, etc.) — no code
# or extra config needed, they just need to be present in the process env.
# docker-compose.yml also reads this file automatically for its ${VAR}
# substitutions if it's named .env and sits next to it.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public URL this instance is reachable at — used to build embed links
# (GET /api/ads/{id}/link). Must match wherever you actually deploy it.
APP_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# MySQL — required. StorageService-style: the app won't start without a
# reachable database (Flyway migrations run at startup).
# ---------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/betterads
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

# ---------------------------------------------------------------------------
# RabbitMQ — required. Drives the ad-processing pipeline
# (upload confirm -> queue -> WorkerConsumer).
# ---------------------------------------------------------------------------
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
SPRING_RABBITMQ_VIRTUAL_HOST=/

# ---------------------------------------------------------------------------
# Redis — required. Backs fraud detection (FraudService, ViewTokenService),
# the funding rate limiter (PaymentRateLimiter), and link caching (LinkService).
# ---------------------------------------------------------------------------
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
# Most hosted Redis providers (Upstash included) require TLS - set to true
# for those, false for a plain local/docker-compose Redis.
SPRING_DATA_REDIS_SSL_ENABLED=false

# ---------------------------------------------------------------------------
# S3 — required. StorageService fails fast at startup if APP_S3_BUCKET is
# blank. AWS credentials are picked up via the SDK's default provider chain,
# so these two env vars are enough (no separate config file needed).
# ---------------------------------------------------------------------------
APP_S3_BUCKET=
APP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Max upload size UploadController will accept at confirm time, in bytes.
# 209715200 = 200MB.
APP_UPLOAD_MAX_SIZE_BYTES=209715200

# ---------------------------------------------------------------------------
# Stripe — optional. Blank is fine: campaign funding just logs a startup
# warning and POST /campaigns/{id}/fund returns a 502 until these are set.
# Everything else in the app works without them.
# ---------------------------------------------------------------------------
APP_STRIPE_SECRET_KEY=
APP_STRIPE_WEBHOOK_SECRET=
# Hard cap per funding request, in dollars.
APP_STRIPE_MAX_FUNDING_AMOUNT=100000

# ---------------------------------------------------------------------------
# Fraud / abuse limits
# ---------------------------------------------------------------------------
APP_FRAUD_MAX_CAMPAIGN_VIEWS_PER_MINUTE=200
APP_FRAUD_MAX_FUNDING_ATTEMPTS_PER_HOUR=5
# Comma-separated IPs/CIDRs allowed to set X-Forwarded-For (e.g. your load
# balancer's internal IP range). Leave blank to never trust the header and
# always use the raw socket address — safe default, but wrong client IPs
# will be recorded if you're actually behind a reverse proxy/LB.
APP_SECURITY_TRUSTED_PROXIES=

# ---------------------------------------------------------------------------
# Placements API — session + playback-event API (Phase 1 of the iframe ->
# SDK migration). Required: SessionTokenService fails fast at startup if
# APP_FRAUD_SESSION_TOKEN_SECRET is blank or under 32 characters. Deliberately
# separate from APP_AUTH_JWT_SECRET so rotating one doesn't affect the other.
# ---------------------------------------------------------------------------
APP_FRAUD_SESSION_TOKEN_SECRET=
APP_PLACEMENTS_SESSION_TTL_MINUTES=15
# Minimum elapsed time (ms) since session issuance before an impression_start
# event is accepted — the IAB viewable-impression floor.
APP_PLACEMENTS_MIN_VIEWABILITY_MS=2000

# ---------------------------------------------------------------------------
# AI provider (moderation / translation / speech eval)
# ---------------------------------------------------------------------------
# mock (default, deterministic, no external calls) | local (calls a
# locally-hosted AI service at APP_AI_LOCAL_BASE_URL) | huggingface (calls
# the hosted moderation Space at APP_AI_HUGGINGFACE_SPACE_URL)
APP_AI_PROVIDER=mock
APP_AI_LOCAL_BASE_URL=http://localhost:9000
APP_AI_HUGGINGFACE_SPACE_URL=https://3amizoubir-ad-moderation.hf.space

# ---------------------------------------------------------------------------
# JWT Auth — required. JwtTokenProvider fails fast at startup if
# APP_AUTH_JWT_SECRET is blank or under 32 characters.
# ---------------------------------------------------------------------------
APP_AUTH_JWT_SECRET=
# 900000 = 15 min access token, 604800000 = 7 days refresh token,
# 1800000 = 30 min password reset token.
APP_AUTH_JWT_EXPIRATION_MS=900000
APP_AUTH_REFRESH_EXPIRATION_MS=604800000
APP_AUTH_RESET_EXPIRATION_MS=1800000

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
APP_RATELIMIT_ENABLED=true
APP_RATELIMIT_REQUESTS_PER_MINUTE=100

# ---------------------------------------------------------------------------
# CORS — must list every origin your frontend is actually served from.
# ---------------------------------------------------------------------------
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
APP_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
APP_CORS_ALLOWED_HEADERS=*
APP_CORS_EXPOSED_HEADERS=Authorization,X-Rate-Limit-Remaining
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_MAX_AGE=3600

# ---------------------------------------------------------------------------
# Logging — optional. Leave unset to use the defaults in
# application.properties. Set LOGGING_FILE_NAME to blank/unset it entirely
# if your host has a read-only or ephemeral filesystem outside a specific
# directory (most PaaS platforms capture stdout regardless).
# ---------------------------------------------------------------------------
LOGGING_LEVEL_ME_PSIKUVIT_BETTERADS=INFO
LOGGING_FILE_NAME=logs/betterads.log
