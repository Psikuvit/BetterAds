# Copy to .env and fill in for anything beyond local/dev defaults.
# docker-compose.yml reads these; unset values fall back to dev-safe defaults.

DB_PASSWORD=pass

APP_BASE_URL=http://localhost:8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Must be at least 32 characters (JwtTokenProvider fails fast otherwise).
APP_AUTH_JWT_SECRET=my-super-secret-jwt-key-change-this-in-production

# Real S3 bucket + AWS credentials for upload presigning. StorageService
# fails fast at startup if APP_S3_BUCKET is blank.
APP_S3_BUCKET=betterads-local-dev
APP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Blank by default — campaign funding logs a startup warning until set.
APP_STRIPE_SECRET_KEY=
APP_STRIPE_WEBHOOK_SECRET=

# mock (default, no external calls) | local (calls a locally-hosted AI service)
APP_AI_PROVIDER=mock
